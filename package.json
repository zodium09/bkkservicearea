{
  "name": "accesibility",
  "version": "1.0.0",
  "description": "Bangkok service area analysis web GIS with QGIS automation hooks.",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 127.0.0.1 --port 5173",
    "server": "node server.js",
    "prepare:data": "node scripts/prepare-bma-layers.js",
    "build": "vite build",
    "test": "node --test test/api/*.test.js",
    "test:api": "node --test test/api/*.test.js",
    "db:migrate": "node scripts/migrate-db.js",
    "import:osm-network": "node scripts/import-osm-network.js",
    "db:topology": "node scripts/build-topology.js",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3"
  }
}
