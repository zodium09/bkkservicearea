{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{backend/**,data/catalog.json,data/processed/bma-layers/layer-13.geojson,data/processed/population/district-population.json}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index?path=:path*"
    }
  ]
}

